{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Countdown Widget",
  "version": "0.1.0",
  "identifier": "com.yu.countdownwidget",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Countdown Widget",
        "width": 320,
        "height": 560,
        "minWidth": 260,
        "maxWidth": 480,
        "minHeight": 360,
        "resizable": true,
        "maximizable": false,
        "skipTaskbar": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  }
}
